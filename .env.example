# 古月浮屿 / World release environment example
# Copy to .env.local in local development. Never commit real secrets.

NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_WORLD_NAME=古月浮屿
NEXT_PUBLIC_WORLD_ENV=preview

# Owner-only APIs. Use a long random value in real environments.
GUYUE_OWNER_TOKEN=replace-with-owner-token
R8_OWNER_TOKEN=replace-with-r8-owner-token

# AI providers are server-only. Public AI must only read public indexes.
OPENAI_API_KEY=
# Current local Goal requires a private-LAN Ollama endpoint. Local Ollama may ignore this compatibility key.
OLLAMA_BASE_URL=http://192.168.x.x:11434
OLLAMA_API_KEY=
OLLAMA_LIGHTHOUSE_MODEL=qwen2.5:7b
AI_PUBLIC_CONTEXT_ONLY=true

# Release evidence placeholders.
PREVIEW_URL=
PRODUCTION_URL=
