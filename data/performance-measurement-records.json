{
  "version": "0.1.0",
  "name": "古月浮屿 V1 性能实测记录模板",
  "principle": "性能实测必须关联页面、设备和指标，而不是只有总分。",
  "routes": [
    {
      "route": "/",
      "device": "mobile",
      "status": "pending",
      "metrics": {
        "lcp": null,
        "inp": null,
        "cls": null,
        "score": null
      }
    },
    {
      "route": "/",
      "device": "desktop",
      "status": "pending",
      "metrics": {
        "lcp": null,
        "inp": null,
        "cls": null,
        "score": null
      }
    },
    {
      "route": "/archive",
      "device": "mobile",
      "status": "pending",
      "metrics": {
        "lcp": null,
        "inp": null,
        "cls": null,
        "score": null
      }
    },
    {
      "route": "/node/[slug]",
      "device": "mobile",
      "status": "pending",
      "metrics": {
        "lcp": null,
        "inp": null,
        "cls": null,
        "score": null
      }
    },
    {
      "route": "/status",
      "device": "desktop",
      "status": "pending",
      "metrics": {
        "lcp": null,
        "inp": null,
        "cls": null,
        "score": null
      }
    },
    {
      "route": "/skeleton",
      "device": "desktop",
      "status": "pending",
      "metrics": {
        "lcp": null,
        "inp": null,
        "cls": null,
        "score": null
      }
    }
  ],
  "thresholds": {
    "lcp": "<= 2.5s target",
    "inp": "<= 200ms target",
    "cls": "<= 0.1 target",
    "score": ">= 90 target where realistic"
  },
  "rules": [
    "移动端首页优先级最高。",
    "状态页/骨架页可较重，但不得破坏核心路径。",
    "低分必须关联具体优化任务。",
    "指标无法采集时必须说明环境。"
  ]
}
