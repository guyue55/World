{
  "version": "0.1.0",
  "principle": "性能守门不仅看数字，也看结构是否允许未来继续优化。",
  "checks": [
    {
      "id": "critical-path-registered",
      "target": "data/domains/experience/critical-path-contract.json"
    },
    {
      "id": "asset-policy-registered",
      "target": "data/domains/governance/static-asset-policy.json"
    },
    {
      "id": "cache-strategy-registered",
      "target": "data/engineering/cache-strategy.json"
    },
    {
      "id": "runtime-split-registered",
      "target": "data/core/runtime-split-contract.json"
    },
    {
      "id": "panel-stack-boundary",
      "target": "src/components/_legacy/WorldFoundationStack.tsx"
    },
    {
      "id": "performance-panel-boundary",
      "target": "src/components/_legacy/world/PerformanceContractPanel.tsx"
    }
  ],
  "rules": [
    "若页面变重，先检查是否应进入 split contract。",
    "若资源变大，先检查是否应进入 asset policy。",
    "若数据变多，先检查是否应进入 cache strategy。",
    "若交互变复杂，先检查是否仍保持 stable layout。"
  ]
}
