{
  "version": "R1",
  "environmentVariables": [
    {
      "name": "NEXT_TELEMETRY_DISABLED",
      "required": true,
      "example": "1"
    },
    {
      "name": "NODE_ENV",
      "required": true,
      "example": "production"
    }
  ],
  "previewSmokeRoutes": [
    "/",
    "/atlas",
    "/timeline",
    "/archive",
    "/paths",
    "/ask",
    "/v10-intelligence",
