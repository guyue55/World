    "src/lib/public-world-surfaces.ts"
  ],
  "forbiddenRuntimeTokens": [
    "OPENAI_API_KEY",
    "ANTHROPIC_API_KEY",
    "new OpenAI",
    "chat.completions",
    "responses.create",
    "streamText(",
