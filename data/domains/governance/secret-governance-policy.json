{
  "version": "0.1.0",
  "name": "古月浮屿 V1 密钥治理与轮换策略",
  "stageProgress": "phase-twelve-platform-governance-service-boundary line batch 2 / 4",
  "status": "secret-governance-prepared",
  "secretGovernanceReady": false,
  "secretClasses": [
    {
      "id": "public-env",
      "storage": "repo-allowed",
      "rotation": "on-change"
    },
    {
      "id": "server-secret",
      "storage": "secret-manager-required",
      "rotation": "quarterly"
    },
    {
      "id": "analytics-token",
      "storage": "secret-manager-required",
      "rotation": "quarterly"
    },
    {
      "id": "storage-credential",
      "storage": "secret-manager-required",
      "rotation": "quarterly"
    },
    {
      "id": "ai-provider-key",
      "storage": "secret-manager-required",
      "rotation": "monthly"
    }
  ],
  "rules": [
    "secretGovernanceReady=false 必须保持，直到真实 secret manager 接入。",
    "secret-manager-required 不得写入仓库。",
    "任何 key 泄露必须触发 rotation 和 audit event。",
    "公开变量必须明确标记 public-env。"
  ]
}
