  "transitions": [
    {
      "id": "gateway-to-atlas",
      "from": "gateway",
      "to": "atlas",
      "motion": "zoom-star",
      "intent": "从书桌入口拉远到世界星图，让访问者理解自己进入了地图层。",
      "reducedMotionFallback": "直接切换到 Atlas，并保留返回入口按钮。"
    },
    {
      "id": "atlas-to-node",
      "from": "atlas",
      "to": "node",
      "motion": "zoom-star",
      "intent": "从星图中的节点放大进入节点房间。",
      "reducedMotionFallback": "直接进入节点页，并显示所在星域。"
    },
    {
      "id": "timeline-to-node",
      "from": "timeline",
      "to": "node",
      "motion": "river-shift",
      "intent": "从时间河中的事件片段展开到对应节点。",
      "reducedMotionFallback": "直接进入节点页，并显示事件日期。"
    },
    {
      "id": "archive-to-node",
      "from": "archive",
      "to": "node",
      "motion": "archive-drawer",
      "intent": "从档案馆抽出一份卷宗进入节点阅读。",
      "reducedMotionFallback": "直接进入节点页，并显示返回档案馆入口。"
    },
    {
      "id": "path-to-node",
      "from": "path-detail",
      "to": "node",
      "motion": "path-arrive",
      "intent": "从旅程路线抵达下一站节点，让访问者知道这是路径中的一步。",
      "reducedMotionFallback": "直接进入节点页，并显示路径返回入口。"
    },
    {
      "id": "default-scene-shift",
      "from": "*",
      "to": "*",
      "motion": "fade-rise",
      "intent": "普通公开场景之间使用轻量抵达过渡。",
      "reducedMotionFallback": "直接显示目标页面。"
    }
  ],
  "fallback": {
    "id": "unknown",
    "match": "*",
    "title": "未命名星域",
    "realName": "通用公开页面",
    "sceneType": "unknown",
    "motionGrammar": "arrival",
    "entryTransition": "fade-rise",
    "exitTransition": "fade-rise",
