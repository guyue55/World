  "acceptance": {
    "requiredSceneMatches": ["/", "/atlas", "/timeline", "/archive", "/paths", "/paths/[id]", "/node/[slug]", "/ask", "/status"],
    "requiredTransitions": ["gateway-to-atlas", "atlas-to-node", "timeline-to-node", "archive-to-node", "path-to-node", "default-scene-shift"],
    "forbiddenRoutePrefixes": ["/_legacy", "/api", "/forbidden"],
    "forbiddenClientTokens": ["OPENAI_API_KEY", "ANTHROPIC_API_KEY", "new OpenAI", "responses.create", "chat.completions", "GUYUE_OWNER_TOKEN", "R8_OWNER_TOKEN"],
    "releaseStates": {
      "productionLive": false,
      "releaseReady": false,
      "cleanProductionReady": false
    }
  },
