{
  "version": "1.0.0",
  "name": "WorldOS M26 世界记忆与回访体验策略",
  "updatedAt": "2026-07-10",
  "source": "docs/00-overview/worldos-m26-world-memory-returning-visitor-spec-2026-07-10.md",
  "principle": "World Memory 只保存公开体验恢复所需的轻量状态，让返回访客继续探索；它不承担权限判断，不保存私密内容，不参与后端 guard。",
  "scope": {
    "localOnly": true,
    "localhostAccepted": true,
    "lanIpAccepted": true,
    "externalPreviewConsidered": false,
    "productionConsidered": false,
    "publicSceneOnly": true,
    "frontendPermissionControl": false,
    "requiresOwner": false,
    "requiresAuth": false,
    "requiresRealAI": false
  },
  "storage": {
    "primaryKey": "guyue-world:journey-memory-v1",
    "historyKey": "guyue-world:journey-history-v1",
    "clearedAtKey": "guyue-world:journey-cleared-at-v1",
    "maxHistory": 5,
    "allowedFields": [
      "path",
      "label",
      "sceneId",
      "sceneTitle",
      "recentNodeSlug",
      "recentPathId",
      "visitedAt"
    ],
    "forbiddenFields": [
      "owner",
      "auth",
      "permission",
      "role",
      "token",
      "secret",
      "visibility",
      "private",
      "vault"
    ]
  },
  "routeRules": [
    {
      "prefix": "/atlas",
      "label": "世界地图",
      "kind": "scene"
    },
    {
      "prefix": "/timeline",
      "label": "时间河",
      "kind": "scene"
    },
    {
      "prefix": "/archive",
      "label": "档案馆",
      "kind": "scene"
    },
    {
      "prefix": "/ask",
      "label": "低光灯塔",
      "kind": "scene"
    },
    {
      "prefix": "/paths/",
      "label": "旅程路线",
      "kind": "path"
    },
    {
      "prefix": "/paths",
      "label": "星路入口",
      "kind": "scene"
    },
    {
      "prefix": "/node/",
      "label": "节点展开室",
      "kind": "node"
    }
  ],
  "fallback": {
    "label": "世界入口",
    "sceneId": "gateway",
    "sceneTitle": "创世原点",
    "path": "/"
  },
  "returningVisitor": {
    "enabled": true,
    "minimumPreviousEntries": 1,
    "continueActionLabel": "继续",
    "emptyState": "当前位置已被轻轻记录。",
    "clearedState": "旅程记忆已清空；继续浏览时只记录公开路径。"
  },
  "clearMemory": {
    "enabled": true,
    "label": "清除",
    "removesKeys": [
      "guyue-world:journey-memory-v1",
      "guyue-world:journey-history-v1"
    ],
    "writesKey": "guyue-world:journey-cleared-at-v1",
    "postClearBehavior": "不显示继续探索；下一次公开路由变化后重新开始轻量记录。"
  },
  "acceptance": {
    "requiredFiles": [
      "data/domains/experience/journey-memory-policy.json",
      "src/lib/journey-memory.ts",
      "src/components/world/WorldRuntimeProvider.tsx",
      "src/components/product/ProductJourneyDock.tsx"
    ],
    "requiredStorageKeys": [
      "guyue-world:journey-memory-v1",
      "guyue-world:journey-history-v1",
      "guyue-world:journey-cleared-at-v1"
    ],
    "forbiddenClientTokens": [
      "OPENAI_API_KEY",
      "ANTHROPIC_API_KEY",
      "new OpenAI",
      "responses.create",
      "chat.completions",
      "GUYUE_OWNER_TOKEN",
      "R8_OWNER_TOKEN"
    ],
    "releaseStates": {
      "productionLive": false,
      "releaseReady": false,
      "cleanProductionReady": false
    }
  },
  "nextActions": [
    "M30 终局候选验收时补 returning visitor 与 cleared storage 的完整录屏。"
  ]
}
