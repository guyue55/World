    "volumeStorageKey": "guyue-world:soundscape-volume",
    "defaultVolume": 0.35,
    "maxVolume": 0.7,
    "usesHtmlAudio": false,
    "usesWebAudio": true,
    "usesExternalAudioAsset": false,
    "usesHowler": false,
    "usesTone": false,
