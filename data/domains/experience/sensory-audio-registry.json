    "maxVolume": 0.7,
    "usesHtmlAudio": false,
    "usesWebAudio": true,
    "usesExternalAudioAsset": false,
    "usesHowler": false,
    "usesTone": false,
    "autoPlayAllowed": false,
    "lazyLoadPolicy": "Web Audio context is created only inside an explicit user click handler.",
    "sessionArmPolicy": "Stored preference never creates audio by itself; every browser session must be armed by a fresh user click.",
    "sceneSwitchPolicy": "Armed sessions keep one procedural ambience group and one short cue; scene changes crossfade for 650-800ms before releasing the previous group.",
    "reducedSensoryPolicy": "silent sensory mode keeps the control visible but never creates or resumes audio."
  },
