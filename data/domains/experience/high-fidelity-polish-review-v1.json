  "requiredFallbackFiles": [
    "src/components/world/WorldFallbackScene.tsx",
    "src/components/common/PageLoader.tsx",
    "src/app/not-found.tsx",
    "src/app/forbidden/page.tsx",
    "src/app/global-error.tsx"
  ],
  "reports": {
    "sceneQa": "docs/90-archive/reports/worldos-scene-qa-report.json",
    "lanRc": "docs/90-archive/reports/worldos-local-lan-rc-report.json",
    "localRc": "docs/90-archive/reports/worldos-local-rc-summary-report.json",
    "audio": "docs/90-archive/reports/worldos-m23-sensory-audio-production-report.json",
    "visualization": "docs/90-archive/reports/worldos-m24-advanced-visualization-report.json",
    "m29": "docs/90-archive/reports/worldos-m29-high-fidelity-polish-report.json"
  },
  "acceptance": {
    "command": "check:m29-high-fidelity-polish",
    "requiredStatusTokens": [
      "High Fidelity Polish M29",
      "截图墙审查",
      "P0/P1",
      "不是 10/10"
