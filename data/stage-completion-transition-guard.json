{
  "version": "0.1.0",
  "name": "古月浮屿 V1 第一阶段完成状态转换守卫",
  "principle": "阶段状态只能由完整证据推动，不能由人工感觉推动。",
  "from": "not-yet-complete",
  "to": "complete",
  "requiredReport": "reports/first-stage-final-closure-report.json",
  "requiredDecision": "complete",
  "updateTargets": [
    "data/stage-completion-gate.json",
    "data/phase-one-final-decision-template.json",
    "reports/first-stage-completion-certificate.json"
  ],
  "blockedWhen": [
    "final closure report is missing",
    "final closure decision is not complete",
    "blockingDefects is not empty",
    "previewUrlRecorded is false",
    "manualQaPassed is false",
    "performancePassed is false"
  ],
  "rules": [
    "转换脚本默认只在证据 complete 时执行。",
    "转换脚本不得伪造验收报告。",
    "完成证书必须包含输入报告摘要。",
    "完成状态更新必须形成单独 delta。"
  ]
}
