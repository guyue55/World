        "motion": "river-shift"
      },
      {
        "from": "/timeline",
        "to": "/archive",
        "transitionId": "timeline-to-archive",
        "motion": "archive-drawer"
      },
      {
        "from": "/archive",
        "to": "/",
        "transitionId": "default-scene-shift",
        "motion": "fade-rise"
      }
    ],
    "acceptance": {
      "requiredMotions": [
        "fade-rise",
        "zoom-star",
        "river-shift",
        "archive-drawer",
        "path-arrive"
      ],
      "requiredSemanticRoutes": [
        "gateway-to-atlas",
        "atlas-to-node",
        "timeline-to-node",
        "archive-to-node",
        "path-to-node",
        "node-to-paths",
        "paths-to-timeline",
        "timeline-to-archive",
        "default-scene-shift"
      ]
    },
    "nextActions": [
      "阶段 29：深化 Atlas、Timeline、Archive、Node、Ask 的场景人格。",
      "阶段 30：建立 Journey Memory 与路径连续性。",
      "阶段 32：把 scene transition 截图证据纳入本地 RC 报告。"
    ]
