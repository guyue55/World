{
  "scene": {
    "name": "WorldOS Phase 26 公开场景注册表",
    "version": "1.0.0",
    "scope": {
      "localOnly": true,
      "localhostAccepted": true,
      "lanIpAccepted": true,
      "externalPreviewConsidered": false,
      "productionConsidered": false,
      "publicSceneOnly": true,
      "frontendPermissionControl": false,
      "requiresOwner": false,
      "requiresRealAI": false
    },
    "scenes": [
      {
        "id": "gateway",
        "match": "/",
        "title": "创世原点",
        "realName": "首页世界入口",
        "sceneType": "gateway",
        "motionGrammar": "arrival",
        "entryTransition": "fade-rise",
        "exitTransition": "gateway-to-atlas",
        "ambientLayer": "desk-starlight",
        "primaryAction": "进入世界地图",
        "href": "/atlas",
        "objects": [
          "书桌",
          "灯",
          "纸页",
          "星河",
          "罗盘"
        ],
        "reducedMotionFallback": "直接显示完整入口、主 CTA 和新手路径，不播放位移或缩放。",
        "publicOnly": true,
        "requiresOwner": false,
        "requiresRealAI": false
      },
      {
        "id": "atlas",
        "match": "/atlas",
        "title": "星图穹顶",
        "realName": "世界地图",
        "sceneType": "atlas",
        "motionGrammar": "connection",
        "entryTransition": "zoom-star",
        "exitTransition": "atlas-to-node",
        "ambientLayer": "constellation-dome",
        "primaryAction": "沿时间河前进",
        "href": "/timeline",
        "objects": [
          "星图",
          "浮屿",
          "路径",
          "雾区"
        ],
        "reducedMotionFallback": "保留区域聚焦和节点列表，禁用星点缩放与连续漂移。",
        "publicOnly": true,
        "requiresOwner": false,
        "requiresRealAI": false
      },
      {
        "id": "timeline",
        "match": "/timeline",
        "title": "时间河",
        "realName": "时间线与事件流",
        "sceneType": "timeline",
        "motionGrammar": "flow",
        "entryTransition": "river-shift",
        "exitTransition": "timeline-to-node",
        "ambientLayer": "time-river",
        "primaryAction": "查看档案馆",
        "href": "/archive",
        "objects": [
          "河流",
          "涟漪",
          "回声",
          "旧星"
        ],
        "reducedMotionFallback": "使用静态事件列表与区域筛选，不播放横向流动。",
        "publicOnly": true,
        "requiresOwner": false,
        "requiresRealAI": false
      },
      {
        "id": "archive",
        "match": "/archive",
        "title": "档案馆",
        "realName": "现实检索与归档",
        "sceneType": "archive",
        "motionGrammar": "emergence",
        "entryTransition": "archive-drawer",
        "exitTransition": "archive-to-node",
        "ambientLayer": "archive-hall",
        "primaryAction": "打开精选路径",
        "href": "/paths",
        "objects": [
          "卷宗",
          "书页",
          "书架",
          "索引"
        ],
        "reducedMotionFallback": "保留检索、筛选和馆藏状态，禁用抽屉位移。",
        "publicOnly": true,
        "requiresOwner": false,
        "requiresRealAI": false
      },
      {
        "id": "paths",
        "match": "/paths",
        "title": "星路入口",
        "realName": "精选探索路径",
        "sceneType": "paths",
        "motionGrammar": "flow",
        "entryTransition": "path-pulse",
        "exitTransition": "fade-rise",
        "ambientLayer": "journey-board",
        "primaryAction": "开始第一条路径",
        "href": "/paths/first-visit",
        "objects": [
          "路径",
          "脚印",
          "节点",
          "星线"
        ],
        "reducedMotionFallback": "直接显示路径卡片、预计时间和下一步，不播放脉冲。",
        "publicOnly": true,
        "requiresOwner": false,
        "requiresRealAI": false
      },
      {
        "id": "path-detail",
        "match": "/paths/[id]",
        "title": "旅程路线",
        "realName": "单条路径详情",
        "sceneType": "path-detail",
        "motionGrammar": "flow",
        "entryTransition": "path-pulse",
        "exitTransition": "path-to-node",
        "ambientLayer": "journey-route",
        "primaryAction": "继续到下一个节点",
        "href": "/archive",
        "objects": [
          "路线",
          "路标",
          "下一站",
          "回望"
        ],
        "reducedMotionFallback": "使用静态步骤序列和下一站按钮，不依赖进度动画。",
        "publicOnly": true,
        "requiresOwner": false,
        "requiresRealAI": false
      },
      {
        "id": "node",
        "match": "/node/[slug]",
        "title": "节点展开室",
        "realName": "内容节点详情",
        "sceneType": "node",
        "motionGrammar": "focus",
        "entryTransition": "node-open",
        "exitTransition": "fade-rise",
        "ambientLayer": "node-room",
        "primaryAction": "回到档案馆",
        "href": "/archive",
        "objects": [
          "护照",
          "卷轴",
          "星线",
          "生命阶段"
        ],
        "reducedMotionFallback": "直接展示节点护照、正文和关系，不播放模糊或放大。",
        "publicOnly": true,
        "requiresOwner": false,
        "requiresRealAI": false
      },
      {
        "id": "lighthouse",
        "match": "/ask",
        "title": "AI 灯塔",
        "realName": "公开导览与问路入口",
        "sceneType": "lighthouse",
        "motionGrammar": "feedback",
        "entryTransition": "lighthouse-sweep",
        "exitTransition": "fade-rise",
        "ambientLayer": "low-light-beacon",
        "primaryAction": "返回世界入口",
        "href": "/",
        "objects": [
          "灯塔",
          "光束",
          "问答",
          "边界"
        ],
        "reducedMotionFallback": "保留推荐问题、路径建议和边界提示，不播放光束扫动。",
        "publicOnly": true,
        "requiresOwner": false,
        "requiresRealAI": false
      },
      {
        "id": "status",
        "match": "/status",
        "title": "维护舱",
        "realName": "公开状态与运行证据",
        "sceneType": "status",
        "motionGrammar": "feedback",
        "entryTransition": "fade-rise",
        "exitTransition": "fade-rise",
        "ambientLayer": "maintenance-console",
        "primaryAction": "返回入口",
        "href": "/",
        "objects": [
          "心跳",
          "状态",
          "证据",
          "低光"
        ],
        "reducedMotionFallback": "直接展示状态账本、门禁结果和下一步建议。",
        "publicOnly": true,
        "requiresOwner": false,
        "requiresRealAI": false
      }
    ],
    "transitions": [
      {
        "id": "gateway-to-atlas",
        "from": "gateway",
        "to": "atlas",
        "motion": "zoom-star",
        "intent": "从书桌入口拉远到世界星图，让访问者理解自己进入了地图层。",
        "reducedMotionFallback": "直接切换到 Atlas，并保留返回入口按钮。"
      },
      {
        "id": "atlas-to-node",
        "from": "atlas",
        "to": "node",
        "motion": "zoom-star",
        "intent": "从星图中的节点放大进入节点房间。",
        "reducedMotionFallback": "直接进入节点页，并显示所在星域。"
      },
      {
        "id": "timeline-to-node",
        "from": "timeline",
        "to": "node",
        "motion": "river-shift",
        "intent": "从时间河中的事件片段展开到对应节点。",
        "reducedMotionFallback": "直接进入节点页，并显示事件日期。"
      },
      {
        "id": "archive-to-node",
        "from": "archive",
        "to": "node",
        "motion": "archive-drawer",
        "intent": "从档案馆抽出一份卷宗进入节点阅读。",
        "reducedMotionFallback": "直接进入节点页，并显示返回档案馆入口。"
      },
      {
        "id": "path-to-node",
        "from": "path-detail",
        "to": "node",
        "motion": "path-arrive",
        "intent": "从旅程路线抵达下一站节点，让访问者知道这是路径中的一步。",
        "reducedMotionFallback": "直接进入节点页，并显示路径返回入口。"
      },
      {
        "id": "node-to-paths",
        "from": "node",
        "to": "paths",
        "motion": "path-arrive",
        "intent": "从节点地点退回旅程入口，把当前节点理解为可继续行走的一站。",
        "reducedMotionFallback": "直接进入路径页，并显示路径选择入口。"
      },
      {
        "id": "paths-to-timeline",
        "from": "paths",
        "to": "timeline",
        "motion": "river-shift",
        "intent": "从路径列表回看时间河，把旅程进度转化为世界发生顺序。",
        "reducedMotionFallback": "直接进入时间河，并保留事件列表。"
      },
      {
        "id": "timeline-to-archive",
        "from": "timeline",
        "to": "archive",
        "motion": "archive-drawer",
        "intent": "从时间河沉入档案馆，把事件线索收束为可检索卷宗。",
        "reducedMotionFallback": "直接进入档案馆，并显示检索与筛选。"
      },
      {
        "id": "default-scene-shift",
        "from": "*",
        "to": "*",
        "motion": "fade-rise",
        "intent": "普通公开场景之间使用轻量抵达过渡。",
        "reducedMotionFallback": "直接显示目标页面。"
      }
    ],
    "fallback": {
      "id": "unknown",
      "match": "*",
      "title": "未命名星域",
      "realName": "通用公开页面",
      "sceneType": "unknown",
      "motionGrammar": "arrival",
      "entryTransition": "fade-rise",
      "exitTransition": "fade-rise",
      "ambientLayer": "soft-breath",
      "primaryAction": "回到入口",
      "href": "/",
      "objects": [
        "雾区",
        "星尘",
        "路标"
      ],
      "reducedMotionFallback": "直接显示页面内容和返回入口。",
      "publicOnly": true,
      "requiresOwner": false,
      "requiresRealAI": false
    },
    "acceptance": {
      "requiredSceneMatches": [
        "/",
        "/atlas",
        "/timeline",
        "/archive",
        "/paths",
        "/paths/[id]",
        "/node/[slug]",
        "/ask",
        "/status"
      ],
      "requiredTransitions": [
        "gateway-to-atlas",
        "atlas-to-node",
        "timeline-to-node",
        "archive-to-node",
        "path-to-node",
        "node-to-paths",
        "paths-to-timeline",
        "timeline-to-archive",
        "default-scene-shift"
      ]
    },
    "nextActions": [
      "阶段 32：将场景、转场和旅程记忆纳入截图 QA。"
    ]
  },
  "transition": {
    "name": "WorldOS Phase 28 公开场景转场注册表",
    "version": "1.0.0",
    "scope": {
      "localOnly": true,
      "localhostAccepted": true,
      "lanIpAccepted": true,
      "externalPreviewConsidered": false,
      "productionConsidered": false,
      "publicSceneOnly": true,
      "frontendPermissionControl": false,
      "requiresOwner": false,
      "requiresAuth": false,
      "requiresRealAI": false
    },
    "shell": {
      "component": "src/components/world/SceneTransitionShell.tsx",
      "mount": "src/components/world/WorldShell.tsx#main-content",
      "usesGsap": true,
      "usesFramerMotionPresence": true,
      "usesViewTransitionApi": false,
      "maxDurationMs": 420,
      "compactMaxDurationMs": 260,
      "reducedMotionBehavior": "直接显示目标页面，不播放位移、缩放或抽屉动作。"
    },
    "motions": [
      {
        "id": "fade-rise",
        "label": "轻量抵达",
        "intent": "普通公开场景之间使用轻量抵达，避免过度打扰阅读。",
        "from": {
          "autoAlpha": 0,
          "y": 14,
          "scale": 1
        },
        "to": {
          "autoAlpha": 1,
          "y": 0,
          "scale": 1,
          "duration": 0.28,
          "ease": "power2.out"
        },
        "compactFrom": {
          "autoAlpha": 0,
          "y": 8,
          "scale": 1
        },
        "reducedMotion": {
          "autoAlpha": 1,
          "x": 0,
          "y": 0,
          "scale": 1
        }
      },
      {
        "id": "zoom-star",
        "label": "星点拉近",
        "intent": "入口到星图、星图到节点时，表达视角拉远或从星点进入。",
        "from": {
          "autoAlpha": 0,
          "y": 8,
          "scale": 0.985
        },
        "to": {
          "autoAlpha": 1,
          "y": 0,
          "scale": 1,
          "duration": 0.36,
          "ease": "power3.out"
        },
        "compactFrom": {
          "autoAlpha": 0,
          "y": 8,
          "scale": 1
        },
        "reducedMotion": {
          "autoAlpha": 1,
          "x": 0,
          "y": 0,
          "scale": 1
        }
      },
      {
        "id": "river-shift",
        "label": "时间河展开",
        "intent": "从时间河进入节点时，用轻微横向流动表达时间片展开。",
        "from": {
          "autoAlpha": 0,
          "x": 18,
          "y": 0,
          "scale": 1
        },
        "to": {
          "autoAlpha": 1,
          "x": 0,
          "y": 0,
          "scale": 1,
          "duration": 0.34,
          "ease": "sine.out"
        },
        "compactFrom": {
          "autoAlpha": 0,
          "y": 8,
          "scale": 1
        },
        "reducedMotion": {
          "autoAlpha": 1,
          "x": 0,
          "y": 0,
          "scale": 1
        }
      },
      {
        "id": "archive-drawer",
        "label": "卷宗抽出",
        "intent": "从档案馆进入节点时，用短促的纵向抽出感表达卷宗被打开。",
        "from": {
          "autoAlpha": 0,
          "y": 18,
          "scale": 0.992
        },
        "to": {
          "autoAlpha": 1,
          "y": 0,
          "scale": 1,
          "duration": 0.34,
          "ease": "power2.out"
        },
        "compactFrom": {
          "autoAlpha": 0,
          "y": 8,
          "scale": 1
        },
        "reducedMotion": {
          "autoAlpha": 1,
          "x": 0,
          "y": 0,
          "scale": 1
        }
      },
      {
        "id": "path-arrive",
        "label": "旅程抵达",
        "intent": "从路径旅程进入节点时，用轻微前进感表达抵达下一站。",
        "from": {
          "autoAlpha": 0,
          "x": -10,
          "y": 8,
          "scale": 0.996
        },
        "to": {
          "autoAlpha": 1,
          "x": 0,
          "y": 0,
          "scale": 1,
          "duration": 0.32,
          "ease": "power2.out"
        },
        "compactFrom": {
          "autoAlpha": 0,
          "y": 8,
          "scale": 1
        },
        "reducedMotion": {
          "autoAlpha": 1,
          "x": 0,
          "y": 0,
          "scale": 1
        }
      }
    ],
    "routeExamples": [
      {
        "from": "/",
        "to": "/atlas",
        "transitionId": "gateway-to-atlas",
        "motion": "zoom-star"
      },
      {
        "from": "/atlas",
        "to": "/node/world-manifesto",
        "transitionId": "atlas-to-node",
        "motion": "zoom-star"
      },
      {
        "from": "/timeline",
        "to": "/node/world-manifesto",
        "transitionId": "timeline-to-node",
