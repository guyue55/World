      "title": "审批服务",
      "dataScope": "metadata-only",
      "state": "planned-service"
    },
    {
      "id": "evidence-service",
      "title": "证据服务",
      "dataScope": "metadata-only",
      "state": "planned-service"
    },
    {
      "id": "private-vault-service",
      "title": "私密档案服务",
      "dataScope": "private-encrypted",
      "state": "future-service"
    },
    {
      "id": "analytics-service",
      "title": "分析服务",
      "dataScope": "public-aggregate",
      "state": "planned-service"
    }
