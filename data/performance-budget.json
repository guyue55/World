{
  "version": "0.1.0",
  "name": "古月浮屿 V1 性能预算",
  "principle": "世界可以宏大，但首次进入必须轻、快、稳。",
  "budgets": [
    {
      "id": "first-load-js",
      "target": "<= 180KB gzip",
      "scope": "critical public route",
      "level": "warning"
    },
    {
      "id": "route-js-growth",
      "target": "<= 30KB per route delta",
      "scope": "route change",
      "level": "warning"
    },
    {
      "id": "homepage-critical-data",
      "target": "<= 60 public nodes summary",
      "scope": "home",
      "level": "warning"
    },
    {
      "id": "archive-initial-render",
      "target": "<= 100 visible cards",
      "scope": "archive",
      "level": "warning"
    },
    {
      "id": "status-panel-stack",
      "target": "heavy panels grouped behind stack/component boundary",
      "scope": "status/skeleton",
      "level": "info"
    },
    {
      "id": "image-policy",
      "target": "all decorative large images lazy or optimized",
      "scope": "public UI",
      "level": "warning"
    },
    {
      "id": "motion-policy",
      "target": "motion must be subtle and avoid layout thrash",
      "scope": "interaction",
      "level": "warning"
    },
    {
      "id": "search-policy",
      "target": "local search index can be split when public nodes grow",
      "scope": "archive/search",
      "level": "info"
    }
  ],
  "rules": [
    "首页不一次性渲染完整世界。",
    "状态页和骨架页可以重，但必须组件化隔离，未来可拆分或懒加载。",
    "动态图形、2.5D、星图、WebXR 不得进入 V1 首屏关键路径。",
    "搜索、图谱、统计、面板类功能必须允许渐进加载。",
    "性能预算超限时优先做结构拆分，而不是压缩可维护性。"
  ]
}
