{
  "version": "0.1.0",
  "name": "古月浮屿 V1 特性模块契约",
  "principle": "特性模块按领域聚合，而不是按临时页面堆放。",
  "featureModules": [
    {
      "id": "world",
      "owns": [
        "world shell",
        "kernel panels",
        "status panels"
      ],
      "paths": [
        "src/components/world",
        "src/lib/world-core.ts",
        "src/lib/world-kernel.ts"
      ]
    },
    {
      "id": "node",
      "owns": [
        "node detail",
        "node badges",
        "node cover"
      ],
      "paths": [
        "src/components/node",
        "src/lib/nodes.ts",
        "src/lib/content.ts"
      ]
    },
    {
      "id": "paths",
      "owns": [
        "path cards",
        "path detail",
        "journey progress"
      ],
      "paths": [
        "src/components/paths",
        "src/lib/paths.ts"
      ]
    },
    {
      "id": "archive",
      "owns": [
        "archive view",
        "search",
        "public discovery"
      ],
      "paths": [
        "src/components/archive",
        "src/lib/search.ts",
        "src/lib/public-index.ts"
      ]
    },
    {
      "id": "governance",
      "owns": [
        "contracts",
        "checks",
        "policies"
      ],
      "paths": [
        "src/lib/*contract*",
        "src/lib/*policy*",
        "scripts/check-*"
      ]
    },
    {
      "id": "interoperability",
      "owns": [
        "manifest",
        "rss",
        "sitemap",
        "export"
      ],
      "paths": [
        "src/lib/rss.ts",
        "src/lib/jsonld.ts",
        "data/export-contract.json"
      ]
    },
    {
      "id": "operations",
      "owns": [
        "runtime",
        "observability",
        "maintenance"
      ],
      "paths": [
        "src/lib/runtime-protocol.ts",
        "src/lib/observability.ts",
        "src/lib/maintenance.ts"
      ]
    },
    {
      "id": "future",
      "owns": [
        "extension interfaces",
        "capability maturity",
        "guardrails"
      ],
      "paths": [
        "src/lib/extensions.ts",
        "data/capability-maturity-model.json"
      ]
    }
  ],
  "rules": [
    "一个 feature module 应拥有清晰领域职责。",
    "跨 feature 复用必须通过 src/lib 或 common component，不互相复制规则。",
    "新增 feature module 必须登记 owns、paths、边界和检查。",
    "模块内部可以高内聚，模块之间必须低耦合。"
  ]
}
